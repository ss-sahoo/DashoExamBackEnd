{
  "info": {
    "name": "Exam & Timetable API Collection",
    "_postman_id": "exam-timetable-collection",
    "description": "Complete API collection for Exam + Timetable backend.\n\n\u2705 BOTH EXAM AND TIMETABLE USE SAME AUTHENTICATION:\n- Role-based login: /api/auth/{role}/login/ (Exam) or /api/timetable/auth/{role}/login/ (Timetable)\n- Both support username, email, or teacher_code\n- Both return same JWT token format\n\nUse environment variables: {{base_url}}, {{superadmin_username}}, {{superadmin_password}}",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Exam (Accounts)",
      "item": [
        {
          "name": "Exam - User Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/register/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "register",
                ""
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user1@example.com\",\n  \"password\": \"User@1234\",\n  \"first_name\": \"Test\",\n  \"last_name\": \"User\"\n}"
            },
            "description": "Registers a generic user in the exam system. Uses accounts.User."
          }
        },
        {
          "name": "Exam - User Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/login/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "login",
                ""
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user1@example.com\",\n  \"password\": \"User@1234\"\n}"
            },
            "description": "Exam-side login (email + password). Returns JWT tokens."
          },
          "description": "Generic Exam login - supports username, email, or teacher_code. Returns JWT tokens in same format as timetable. Use role-based login for better control."
        },
        {
          "name": "Exam - User Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/logout/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "logout",
                ""
              ]
            },
            "description": "Logs out the current user (uses Django session/JWT blacklisting depending on implementation)."
          }
        },
        {
          "name": "Exam - User Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{exam_access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/profile/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "profile",
                ""
              ]
            },
            "description": "Get current logged-in exam user profile."
          }
        }
      ]
    },
